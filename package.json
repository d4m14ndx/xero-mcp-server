{
  "name": "xero-mcp-server",
  "version": "0.3.0",
  "description": "MCP server for Xero accounting API (invoices, bills, payments, bank transactions, attachments, billable expenses)",
  "license": "MIT",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "xero",
    "accounting",
    "claude"
  ],
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "xero-mcp-server": "dist/index.js"
  },
  "scripts": {
    "start": "node dist/index.js",
    "auth": "node scripts/auth.mjs",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "clean": "rm -rf dist",
    "inspector": "npx @modelcontextprotocol/inspector node dist/index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "open": "^11.0.0",
    "xero-node": "^13.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
