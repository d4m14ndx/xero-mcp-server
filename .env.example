# Xero Custom Connection credentials
# Create one at https://developer.xero.com/app/manage/ (choose "Custom connection")
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=

# Optional: override default scopes (space-separated). Custom Connections inherit
# scopes configured on the app; usually no need to set this.
# XERO_SCOPES=accounting.transactions accounting.contacts accounting.settings
